# Ayaka Blog 生产环境 .env 模板
# 用法：
# 1. 把本文件复制为服务器上的真实 .env 文件。
# 2. 先填写“最低必填配置”，项目就能启动。
# 3. “可选高级配置”不填时，大多会走 application.yml 里的默认值。
# 4. 带 replace_with_* 的值必须替换成你自己的真实配置。
# 5. 本文件可以被 start.sh 直接 source，所以不要把中文说明写进真正的值里。

############################
# 最低必填配置 / Minimum Required
############################
# 这一部分建议优先填写；数据库、邮件、JWT 是后端正常运行的基础。
# 如果你启用了 Turnstile，那么对应的 Site Key / Secret Key 也属于必填。

# Server / 服务端口
SERVER_PORT=8080  # Spring Boot 服务监听端口，默认 8080

# Database / 数据库
DB_HOST=127.0.0.1  # MySQL 主机地址，本机数据库通常写 127.0.0.1
DB_PORT=3306  # MySQL 端口，默认 3306
DB_USERNAME=replace_with_your_db_username  # MySQL 用户名
DB_PASSWORD=replace_with_your_db_password  # MySQL 密码，必须替换

# Mail / 邮件 SMTP
MAIL_HOST= # SMTP 服务器地址，例如 smtp.qq.com / smtp.exmail.qq.com
MAIL_PORT= # SMTP 端口，SSL 常用 465
MAIL_USERNAME=no-reply@example.com  # 发件邮箱账号
MAIL_PASSWORD=replace_with_your_smtp_password  # SMTP 授权码或邮箱密码，必须替换
MAIL_FROM_NAME= # 邮件发件人名称
MAIL_FROM_ADDRESS=no-reply@example.com  # 邮件发件人地址，通常与 MAIL_USERNAME 一致

# JWT / 登录令牌
ANIME_BLOG_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars  # JWT 密钥，至少 32 个字符，必须替换

# CORS / 跨域白名单
CORS_ALLOWED_ORIGINS=  # 允许跨域访问的来源，多个值用英文逗号分隔；启用 HTTPS 后请使用 https://

# Upload / 上传与存储
APP_UPLOAD_DIR=  # 上传文件保存目录，建议写绝对路径

# Cloudflare Turnstile / 人机验证
TURNSTILE_ENABLED=false  # 是否启用 Turnstile，总开关；不使用时保持 false
TURNSTILE_SITE_KEY=replace_with_your_turnstile_site_key  # Turnstile 前端 Site Key，可公开；不用可留占位值
TURNSTILE_SECRET_KEY=replace_with_your_turnstile_secret_key  # Turnstile 后端 Secret Key，严禁泄露；不用可留占位值

############################
# 可选高级配置 / Optional Advanced
############################
# 这一部分主要用于调优、增强功能、兼容特殊部署环境。
# 不填时多数会使用项目默认值。

# 数据库高级配置
DB_USE_SSL=false  # 是否启用数据库 SSL，常规内网部署一般为 false
DB_ALLOW_PUBLIC_KEY=false  # 是否允许 MySQL 公钥获取，普通本机部署一般为 false

# JWT配置
JWT_ACCESS_EXPIRE=7200  # Access Token 过期时间，单位秒，7200=2小时
JWT_REFRESH_EXPIRE=2592000  # Refresh Token 过期时间，单位秒，2592000=30天

# Upload / 上传与存储
APP_MUSIC_MAX_AUDIO_FILE_SIZE_BYTES=104857600  # 音频文件最大大小，单位字节，104857600=100MB
APP_MUSIC_MAX_COVER_FILE_SIZE_BYTES=10485760  # 音乐封面最大大小，单位字节，10485760=10MB
APP_POST_IMAGE_MAX_FILES=10  # 单篇文章图片上传最大数量
APP_POST_IMAGE_MAX_FILE_SIZE_BYTES=5242880  # 单张文章图片最大大小，单位字节，5242880=5MB
APP_POST_IMAGE_MAX_TOTAL_SIZE_BYTES=20971520  # 单次文章图片上传总大小上限，单位字节，20971520=20MB
SPRING_MULTIPART_MAX_FILE_SIZE=128MB  # Spring 单文件上传大小上限
SPRING_MULTIPART_MAX_REQUEST_SIZE=160MB  # Spring 单次请求总上传大小上限


# IP Location / IP 归属地解析
APP_IP_LOCATION_ENABLED=true  # 是否启用 IP 归属地解析
APP_AMAP_IP_KEY=replace_with_your_amap_key_or_leave_blank  # 高德 IP 定位 Key，不用可留空
APP_AMAP_IP_ENDPOINT=https://restapi.amap.com/v3/ip  # 高德 IP 查询接口地址，一般保持默认
APP_IP_LOCATION_GLOBAL_FALLBACK_ENABLED=true  # 高德失败后是否启用全球兜底 IP 查询
APP_IP_LOCATION_GLOBAL_FALLBACK_ENDPOINT=https://api.ip2location.io/  # 全球兜底 IP 查询接口地址
APP_IP_LOCATION_GLOBAL_FALLBACK_API_KEY=replace_with_your_ip2location_key_or_leave_blank  # ip2location API Key，不用可留空
APP_IP_LOCATION_CACHE_TTL_SECONDS=31536000  # IP 成功解析缓存时间，单位秒，31536000=365天
APP_IP_LOCATION_FAILURE_CACHE_TTL_SECONDS=21600  # IP 解析失败缓存时间，单位秒，21600=6小时
APP_IP_LOCATION_CONNECT_TIMEOUT_MILLIS=2500  # IP 查询连接超时，单位毫秒
APP_IP_LOCATION_READ_TIMEOUT_MILLIS=2500  # IP 查询读取超时，单位毫秒

# Logging / 日志级别
LOG_LEVEL_APP=INFO  # 项目业务日志级别，可选 TRACE / DEBUG / INFO / WARN / ERROR
LOG_LEVEL_SECURITY=INFO  # Spring Security 日志级别，排查登录问题时可临时改为 DEBUG

# Cloudflare Turnstile / 人机验证
TURNSTILE_VERIFY_ENDPOINT=https://challenges.cloudflare.com/turnstile/v0/siteverify  # Turnstile 校验接口，一般保持默认
TURNSTILE_CONNECT_TIMEOUT_MILLIS=2500  # Turnstile 连接超时，单位毫秒
TURNSTILE_READ_TIMEOUT_MILLIS=4000  # Turnstile 读取超时，单位毫秒
TURNSTILE_LOGIN_ENABLED=true  # 是否为登录失败场景启用 Turnstile
TURNSTILE_LOGIN_FAILURE_THRESHOLD=3  # 登录连续失败多少次后开始要求人机验证
TURNSTILE_LOGIN_FAILURE_WINDOW_MILLIS=1800000  # 统计登录失败次数的时间窗口，单位毫秒，1800000=30分钟
TURNSTILE_REGISTER_EMAIL_CHECK_ENABLED=true  # 注册时“发送邮箱验证码”前是否要求人机验证
TURNSTILE_COMMENT_GUEST_CHECK_ENABLED=true  # 游客 / 匿名评论前是否要求人机验证
